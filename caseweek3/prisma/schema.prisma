generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "mysql"
}

model news {
  id        Int      @id @default(autoincrement())
  judul     String   @unique(map: "News_judul_key")
  konten    String
  penulis   String
  thumbnail String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model users {
  id          Int      @id @default(autoincrement())
  username    String
  email       String   @unique
  password    String
  role        Role     @default(READER)
  dateOfBirth DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  READER
  WRITER
  EDITOR
  ADMIN
}
